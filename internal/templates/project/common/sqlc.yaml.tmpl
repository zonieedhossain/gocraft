version: "2"
sql:
  - schema: "internal/repository/schema.sql"
    queries: "internal/repository/query.sql"
    engine: "{{ if eq .DB "postgres" }}postgresql{{ else if eq .DB "mysql" }}mysql{{ else }}sqlite{{ end }}"
    gen:
      go:
        package: "repository"
        out: "internal/repository"
        emit_interface: true
        emit_json_tags: true
        emit_prepared_queries: true
        emit_db_tags: true
