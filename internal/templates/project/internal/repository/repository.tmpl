package repository

import (
	"{{ .ModulePath }}/internal/domain"
	{{ if eq .ORM "gorm" }}
	"gorm.io/gorm"
	{{ else if eq .ORM "bun" }}
	"context"
	"github.com/uptrace/bun"
	{{ else }}
	"database/sql"
	{{ end }}
)

type UserRepo struct {
	{{ if eq .ORM "gorm" }}
	db *gorm.DB
	{{ else if eq .ORM "bun" }}
	db *bun.DB
	{{ else }}
	db *sql.DB
	{{ end }}
}

func NewRepository(db {{ if eq .ORM "gorm" }}*gorm.DB{{ else if eq .ORM "bun" }}*bun.DB{{ else }}*sql.DB{{ end }}) domain.UserRepository {
	return &UserRepo{db: db}
}

{{ if eq .ORM "gorm" }}
func (r *UserRepo) GetAll() ([]domain.User, error) {
	var users []domain.User
	err := r.db.Find(&users).Error
	return users, err
}

func (r *UserRepo) GetByID(id uint) (domain.User, error) {
	var user domain.User
	err := r.db.First(&user, id).Error
	return user, err
}

func (r *UserRepo) Create(user *domain.User) error {
	return r.db.Create(user).Error
}

func (r *UserRepo) Update(user *domain.User) error {
	return r.db.Save(user).Error
}

func (r *UserRepo) Delete(id uint) error {
	return r.db.Delete(&domain.User{}, id).Error
}

{{ else if eq .ORM "bun" }}
func (r *UserRepo) GetAll() ([]domain.User, error) {
	var users []domain.User
	err := r.db.NewSelect().Model(&users).Scan(context.Background())
	return users, err
}

func (r *UserRepo) GetByID(id uint) (domain.User, error) {
	var user domain.User
	err := r.db.NewSelect().Model(&user).Where("id = ?", id).Scan(context.Background())
	return user, err
}

func (r *UserRepo) Create(user *domain.User) error {
	_, err := r.db.NewInsert().Model(user).Exec(context.Background())
	return err
}

func (r *UserRepo) Update(user *domain.User) error {
	_, err := r.db.NewUpdate().Model(user).WherePK().Exec(context.Background())
	return err
}

func (r *UserRepo) Delete(id uint) error {
	_, err := r.db.NewDelete().Model((*domain.User)(nil)).Where("id = ?", id).Exec(context.Background())
	return err
}

{{ else }}
// sqlc or raw sql logic here
func (r *UserRepo) GetAll() ([]domain.User, error) {
	// Implementation for raw SQL or sqlc
	return nil, nil
}

func (r *UserRepo) GetByID(id uint) (domain.User, error) {
	return domain.User{}, nil
}

