package repository

import (
	"{{ .ModulePath }}/internal/domain"
	{{ if eq .ORM "gorm" }}
	"gorm.io/gorm"
	{{ else if eq .ORM "bun" }}
	"context"
	"github.com/uptrace/bun"
	{{ else }}
	"database/sql"
