package main

import (
	"fmt"
	"log"
	"os"

	"github.com/joho/godotenv"
	"{{ .ModulePath }}/internal/infrastructure"
	"{{ .ModulePath }}/internal/delivery/http"
	"{{ .ModulePath }}/internal/repository"
	"{{ .ModulePath }}/internal/usecase"
)

func main() {
	// Load environment variables
	if err := godotenv.Load(); err != nil {
		log.Println("⚠️ No .env file found, relying on environment variables")
	}

	// Initialize Infrastructure (DB)
	db, err := infrastructure.NewDB()
	if err != nil {
		log.Fatalf("Database connection failed: %v", err)
	}

	// Initialize Layers (Clean Architecture)
	repo := repository.NewRepository(db)
	logic := usecase.NewUsecase(repo)
	
	// Start Web Server
	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}

	fmt.Printf("Starting server on port %s using {{ .Web }} framework\n", port)
	if err := http.StartServer(logic, port); err != nil {
		log.Fatalf("Server failed: %v", err)
	}
}
